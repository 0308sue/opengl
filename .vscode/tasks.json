{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "OpenGL Build Active File",
			"command": "/bin/zsh",
			"args": [
				"-c",
				"/usr/bin/clang++ -std=c++17 -fdiagnostics-color=always -Wall -g \"${file}\" \"${workspaceFolder}/glad.c\" -I\"${workspaceFolder}/dependencies/include\" \"${workspaceFolder}/dependencies/library/libglfw.3.4.dylib\" -o \"${fileDirname}/${fileBasenameNoExtension}\" -framework OpenGL -framework Cocoa -framework IOKit -framework CoreVideo -framework CoreFoundation -Wno-deprecated-declarations && echo '✅ 빌드 완료!!'"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}

